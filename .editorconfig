root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Markdown uses trailing double-spaces for line breaks — don't strip them,
# and don't let an editor rewrap prose (rewrap = whole-file diff = conflicts).
[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{py,ts,tsx,json}]
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
